{
  "name": "cypress-tests",
  "version": "1.0.0",
  "description": "Test cases in cypress",
  "main": "cypress.config.js",
  "scripts": {
    "format:cypress": "prettier --write \"cypress/**/*.{js,ts,jsx,tsx}\"",
    "lint": "./node_modules/.bin/tslint -c tslint.json -p cypress/**/*.ts -t stylish",
    "start":          "cypress open",
    "start:sandbox":  "TEST_ENV=sandbox cypress open",
    "start:integ":    "TEST_ENV=integ   cypress open",
    "start:local":    "TEST_ENV=local   cypress open",
    "test":           "cypress run",
    "test:sandbox":   "TEST_ENV=sandbox cypress run",
    "test:integ":     "TEST_ENV=integ   cypress run",
    "test:local":     "TEST_ENV=local   cypress run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juspay/hyperswitch-web/cypress-tests"
  },
  "author": "juspay/hyperswitch-web-sdk",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.13.2",
    "cypress-iframe": "^1.0.1",
    "prettier": "^3.6.2",
    "typescript": "^5.5.4"
  }
}
