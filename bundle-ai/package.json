  "description": "Bundle analyzer for Hyperswitch Web SDK - optimized for ReScript/React/Webpack projects",
  "main": "cli.js",
  "bin": {
    "bundle-analyze": "./cli.js"
  },
  "scripts": {
    "analyze": "node cli.js",
